# ============================================================================
# Auto-Claude 环境变量配置
# ============================================================================
# 将此文件复制到 ~/.auto-claude/config.env 并填写实际值
# 安装脚本会自动完成复制: bash config/install.sh
# ============================================================================

# ----------------------------------------------------------------------------
# Telegram 通知配置
# ----------------------------------------------------------------------------

# Telegram Bot Token — 从 @BotFather 创建 Bot 后获取
TG_BOT_TOKEN=your-bot-token-here

# 接收通知的 Chat ID — 可以是个人聊天、群组或频道的 ID
# 获取方式: 给 Bot 发消息后访问 https://api.telegram.org/bot<TOKEN>/getUpdates
TG_CHAT_ID=your-chat-id-here

# Channel Unix Socket 路径 — daemon 和 hook 通信用
# 默认: ~/.auto-claude/channel.sock
CHANNEL_SOCKET=~/.auto-claude/channel.sock

# ----------------------------------------------------------------------------
# Auto-Continue 自动续命配置
# ----------------------------------------------------------------------------

# 最大续命次数 — 防止无限循环，达到上限后停止并通知
# 默认: 20
MAX_CONTINUATIONS=20

# 连续阻止次数上限 — stop_hook_active=true 时不立即放行，
# 允许连续 block 最多 N 次。默认 10 意味着 CC 可以连续干 10 轮不停
# 默认: 10
MAX_CONSECUTIVE_BLOCKS=10

# 子代理完成时是否发送 Telegram 通知（频繁的子代理完成可能导致刷屏）
# 默认: false
NOTIFY_ON_SUBAGENT=false

# 每次续命时是否发送 Telegram 通知
# 默认: true
NOTIFY_ON_CONTINUE=true

# ----------------------------------------------------------------------------
# 文件路径配置
# ----------------------------------------------------------------------------

# 状态文件目录 — 存放每个 session 的运行状态 JSON
# 默认: ~/.auto-claude/state
STATE_DIR=~/.auto-claude/state

# 日志目录 — 存放运行日志
# 默认: ~/.auto-claude/logs
LOG_DIR=~/.auto-claude/logs
