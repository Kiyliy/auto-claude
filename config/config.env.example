# ============================================================================
# Auto-Claude 配置
# ============================================================================
# 复制到 ~/.auto-claude/config.env 并填写实际值

# --- Telegram ---
TG_BOT_TOKEN=your-bot-token-here
TG_CHAT_ID=your-chat-id-here
# CHANNEL_SOCKET=~/.auto-claude/channel.sock

# --- 续命控制 ---
MAX_CONTINUATIONS=20
MAX_CONSECUTIVE_BLOCKS=10
NOTIFY_ON_CONTINUE=true

# --- 路径 ---
# STATE_DIR=~/.auto-claude/state
# LOG_DIR=~/.auto-claude/logs
